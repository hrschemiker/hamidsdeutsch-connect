{
    "name": "hamidsdeutsch-connect",
    "private": true,
    "version": "1.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:electron": "wait-on http://localhost:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron electron/main.cjs",
        "start": "concurrently -k \"npm:dev\" \"npm:dev:electron\"",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "dist:win": "npm run build && electron-builder --config electron-builder.yml --win nsis --x64",
        "pack:win": "npm run build && electron-builder --config electron-builder.yml --win dir --x64",
        "release:check": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release-preflight.ps1"
    },
    "dependencies": {
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^24.13.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "concurrently": "^10.0.3",
        "cross-env": "^10.1.0",
        "electron": "^42.5.0",
        "electron-builder": "^26.15.3",
        "eslint": "^10.5.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.6.0",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.1.0",
        "wait-on": "^9.0.10"
    },
    "productName": "HamidsDeutsch Connect",
    "description": "Secure Windows VPN client powered by sing-box.",
    "author": "HamidsDeutsch",
    "main": "electron/main.cjs"
}
